{
  "manifest_version": 3,
  "name": "AI Translator EN→VI",
  "version": "1.0.0",
  "description": "Dịch Anh → Việt bằng AI local (Ollama) hoặc cloud (Google Gemini). Hỗ trợ RAG cho Q&A.",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-wM4Izr4w.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "wasm/*",
        "assets/content.js-wM4Izr4w.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
